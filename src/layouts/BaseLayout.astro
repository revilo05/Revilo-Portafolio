---
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Oliver Abreu Mateo — Full Stack Developer',
  description = 'Portafolio profesional de Oliver Abreu Mateo.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
