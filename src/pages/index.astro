---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/data/site';
---

<BaseLayout title={`${siteConfig.name} — ${siteConfig.role}`} description={siteConfig.description}>
  <main>
    <section class="hero container">
      <p class="eyebrow">{siteConfig.role} · Santo Domingo</p>
      <h1>
        Construyo productos web escalables y experiencias
        <span> digitales memorables.</span>
      </h1>
      <p class="lead">{siteConfig.description}</p>
      <div class="actions">
        <a class="primary" href="#proyectos">Ver proyectos</a>
        <a class="secondary" href="#sobre-mi">Conocer mi trabajo</a>
      </div>
      <p class="availability">Disponible para oportunidades y colaboraciones</p>
    </section>

    <section id="proyectos" class="placeholder container">
      <p class="eyebrow">Proyectos seleccionados</p>
      <h2>Casos de estudio, no solo tarjetas</h2>
      <p>La implementación visual completa se desarrollará a partir del diseño aprobado en Figma.</p>
    </section>

    <section id="sobre-mi" class="placeholder container">
      <p class="eyebrow">Sobre mí</p>
      <h2>Desarrollador orientado a producto y arquitectura</h2>
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    min-height: 78vh;
    display: grid;
    align-content: center;
    padding-block: 7rem 5rem;
  }

  .eyebrow {
    color: var(--color-secondary);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 900px;
    margin: 1rem 0;
    font-size: clamp(2.7rem, 7vw, 5.6rem);
    line-height: 0.98;
    letter-spacing: -0.055em;
  }

  h1 span {
    color: var(--color-primary);
  }

  .lead {
    max-width: 700px;
    color: var(--color-muted);
    font-size: 1.1rem;
    line-height: 1.7;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }

  .actions a {
    padding: 0.9rem 1.25rem;
    border-radius: 0.75rem;
    font-weight: 700;
  }

  .primary {
    background: var(--color-primary);
  }

  .secondary {
    border: 1px solid var(--color-border);
    background: var(--color-surface-soft);
  }

  .availability {
    margin-top: 1.75rem;
    color: var(--color-success);
  }

  .placeholder {
    padding-block: 6rem;
    border-top: 1px solid var(--color-border);
  }

  h2 {
    font-size: clamp(2rem, 4vw, 3.5rem);
    margin: 0.75rem 0;
  }

  .placeholder > p:last-child {
    color: var(--color-muted);
  }
</style>
